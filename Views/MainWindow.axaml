<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OnlineStoreAvalonia.ViewModels"
        xmlns:models="using:OnlineStoreAvalonia.Models"
        x:Class="OnlineStoreAvalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="Root"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="650"
        Icon="/Assets/avalonia-logo.ico"
        Title="Интернет магазин">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#172033"/>
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#687083"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#DDE3ED"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#1F6FEB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.flat">
            <Setter Property="Background" Value="#EEF2F8"/>
            <Setter Property="Foreground" Value="#172033"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#B42318"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.logout">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#172033"/>
            <Setter Property="BorderBrush" Value="#DDE3ED"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
    </Window.Styles>

    <Grid Background="#F4F6FA">
        <Grid IsVisible="{Binding IsLoginVisible}" Margin="28">
            <Grid RowDefinitions="Auto,Auto" MaxWidth="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,22">
                    <TextBlock Text="{Binding AppTitle}"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#172033"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding LoginSubtitle}"
                               Foreground="#687083"
                               FontSize="15"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                    <Button Classes="flat"
                            Content="{Binding LanguageButtonText}"
                            Command="{Binding ToggleLanguageCommand}"
                            Width="58"
                            Height="34"
                            HorizontalAlignment="Center"
                            Margin="0,12,0,0"/>
                </StackPanel>

                <Border Grid.Row="1" Classes="panel">
                    <Grid>
                    <StackPanel Spacing="12" IsVisible="{Binding IsLoginFormVisible}">
                        <TextBlock Classes="section-title" Text="{Binding LoginTitle}"/>
                        <TextBox PlaceholderText="{Binding LoginPlaceholder}" Text="{Binding ClientLogin}"/>
                        <TextBox PlaceholderText="{Binding PasswordPlaceholder}"
                                 Text="{Binding ClientPassword}"
                                 PasswordChar="*"/>
                        <Button Classes="primary"
                                Content="{Binding LoginButtonText}"
                                Command="{Binding LoginCommand}"
                                Height="40"/>
                        <Button Classes="flat"
                                Content="{Binding NoAccountText}"
                                Command="{Binding ShowRegistrationCommand}"
                                Height="36"/>
                        <TextBlock Text="{Binding AuthMessage}"
                                   Foreground="#A33B25"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Spacing="12" IsVisible="{Binding IsRegistrationFormVisible}">
                        <TextBlock Classes="section-title" Text="{Binding RegisterTitle}"/>
                        <TextBox PlaceholderText="{Binding FullNamePlaceholder}" Text="{Binding RegisterFullName}"/>
                        <TextBox PlaceholderText="{Binding Phone13Placeholder}"
                                 Text="{Binding RegisterPhone, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="13"/>
                        <TextBox PlaceholderText="{Binding LoginPlaceholder}" Text="{Binding RegisterLogin}"/>
                        <TextBox PlaceholderText="{Binding PasswordPlaceholder}"
                                 Text="{Binding RegisterPassword}"
                                 PasswordChar="*"/>
                        <Button Classes="primary"
                                Content="{Binding RegisterButtonText}"
                                Command="{Binding RegisterClientCommand}"
                                Height="40"/>
                        <Button Classes="flat"
                                Content="{Binding AlreadyAccountText}"
                                Command="{Binding ShowLoginCommand}"
                                Height="36"/>
                        <TextBlock Text="{Binding AuthMessage}"
                                   Foreground="#A33B25"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid IsVisible="{Binding IsStoreVisible}" RowDefinitions="Auto,*">
        <Border Background="#172033" Padding="24,18">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                <StackPanel>
                    <TextBlock Text="{Binding AppTitle}"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#263551"
                        CornerRadius="8"
                        Padding="14,10"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding CartSummary}" Foreground="White" FontWeight="SemiBold"/>
                </Border>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentUserTitle}"
                               Foreground="#C9D3E4"
                               VerticalAlignment="Center"/>
                    <Button Classes="logout"
                            Content="{Binding LanguageButtonText}"
                            Command="{Binding ToggleLanguageCommand}"
                            Height="34"/>
                    <Button Classes="logout"
                            Content="{Binding LogoutText}"
                            Command="{Binding LogoutCommand}"
                            Height="34"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="2*,420" ColumnSpacing="18" Margin="22">
            <Grid RowDefinitions="Auto,*" RowSpacing="14">
                <Border Classes="panel">
                    <Grid ColumnDefinitions="*,220" ColumnSpacing="12">
                        <TextBox PlaceholderText="{Binding SearchPlaceholder}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="42"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory}"
                                  Height="42"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Classes="panel" Padding="0">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Classes="section-title" Text="{Binding CatalogTitle}" Margin="16,14,16,8"/>
                        <ScrollViewer Grid.Row="1" Padding="16,0,16,16">
                            <ItemsControl ItemsSource="{Binding Products}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:Product">
                                        <Border Width="250"
                                                MinHeight="250"
                                                Margin="0,0,12,12"
                                                Padding="14"
                                                Background="#FFFFFF"
                                                BorderBrush="#DDE3ED"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
                                                <Border Height="82"
                                                        Background="{Binding AccentColor}"
                                                        CornerRadius="8"
                                                        Margin="0,0,0,12">
                                                    <TextBlock Text="{Binding CategoryIcon}"
                                                               FontSize="30"
                                                               FontWeight="Bold"
                                                               Foreground="#172033"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Row="1">
                                                    <TextBlock Text="{Binding Category}" Classes="muted"/>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"
                                                               Margin="0,3,0,0"/>
                                                </StackPanel>
                                                <TextBlock Grid.Row="2"
                                                           Text="{Binding Description}"
                                                           TextWrapping="Wrap"
                                                           Foreground="#4D5668"
                                                           Margin="0,10,0,0"/>
                                                <StackPanel Grid.Row="3" VerticalAlignment="Bottom" Margin="0,12,0,0">
                                                    <TextBlock Text="{Binding Price, StringFormat='{}{0:N0} ₸'}"
                                                               FontSize="20"
                                                               FontWeight="Bold"
                                                               Foreground="#0B7A53"/>
                                                    <TextBlock Text="{Binding Stock, StringFormat='Stock: {0}'}"
                                                               Classes="muted"/>
                                                </StackPanel>
                                                <Button Grid.Row="4"
                                                        Classes="primary"
                                                        Content="{Binding #Root.DataContext.AddToCartText}"
                                                        IsVisible="{Binding #Root.DataContext.IsCustomerPanelVisible}"
                                                        Command="{Binding #Root.DataContext.AddToCartCommand}"
                                                        CommandParameter="{Binding}"
                                                        Height="36"
                                                        Margin="0,12,0,0"/>
                                                <Button Grid.Row="4"
                                                        Classes="danger"
                                                        Content="{Binding #Root.DataContext.DeleteProductText}"
                                                        IsVisible="{Binding #Root.DataContext.IsStaffPanelVisible}"
                                                        Command="{Binding #Root.DataContext.DeleteProductCommand}"
                                                        CommandParameter="{Binding}"
                                                        Height="36"
                                                        Margin="0,12,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*" RowSpacing="14">
                <Border Classes="panel" IsVisible="{Binding IsCustomerPanelVisible}">
                    <Grid RowDefinitions="Auto,Auto,Auto">
                        <TextBlock Classes="section-title" Text="{Binding CartTitle}"/>
                        <ScrollViewer Grid.Row="1" MaxHeight="210" Margin="0,12,0,10">
                            <ItemsControl ItemsSource="{Binding CartItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:CartItem">
                                        <Border BorderBrush="#E5EAF2"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,8">
                                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Product.Name}"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding LineTotal, StringFormat='{}{0:N0} ₸'}"
                                                               Foreground="#0B7A53"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            Spacing="6"
                                                            VerticalAlignment="Center">
                                                    <Button Classes="flat"
                                                            Content="-"
                                                            Width="32"
                                                            Command="{Binding #Root.DataContext.DecreaseQuantityCommand}"
                                                            CommandParameter="{Binding}"/>
                                                    <TextBlock Text="{Binding Quantity}"
                                                               Width="28"
                                                               TextAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontWeight="SemiBold"/>
                                                    <Button Classes="flat"
                                                            Content="+"
                                                            Width="32"
                                                            Command="{Binding #Root.DataContext.IncreaseQuantityCommand}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="x"
                                                            Width="32"
                                                            Command="{Binding #Root.DataContext.RemoveFromCartCommand}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding TotalText}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CartTotal, StringFormat='{}{0:N0} ₸'}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#0B7A53"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Classes="panel" IsVisible="{Binding IsCustomerPanelVisible}">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="section-title" Text="{Binding CheckoutTitle}"/>
                        <TextBox PlaceholderText="{Binding CustomerFullNamePlaceholder}" Text="{Binding CustomerName}"/>
                        <TextBox PlaceholderText="{Binding Phone13Placeholder}"
                                 Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="13"/>
                        <TextBox PlaceholderText="{Binding AddressPlaceholder}" Text="{Binding Address}"/>
                        <Button Classes="primary"
                                Content="{Binding CheckoutButtonText}"
                                Command="{Binding CheckoutCommand}"
                                Height="40"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap"
                                   Foreground="#4D5668"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.RowSpan="3" Classes="panel" IsVisible="{Binding IsStaffPanelVisible}">
                    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="14">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="section-title" Text="{Binding AddProductTitle}"/>
                            <TextBox PlaceholderText="{Binding ProductNamePlaceholder}" Text="{Binding NewProductName}"/>
                            <ComboBox PlaceholderText="{Binding CategoryPlaceholder}"
                                      ItemsSource="{Binding AdminCategories}"
                                      SelectedItem="{Binding NewProductCategory}"/>
                            <TextBox PlaceholderText="{Binding DescriptionPlaceholder}" Text="{Binding NewProductDescription}"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <TextBox PlaceholderText="{Binding PricePlaceholder}" Text="{Binding NewProductPrice}"/>
                                <TextBox Grid.Column="1" PlaceholderText="{Binding StockPlaceholder}" Text="{Binding NewProductStock}"/>
                            </Grid>
                            <Button Classes="primary"
                                    Content="{Binding AddProductButtonText}"
                                    Command="{Binding AddProductCommand}"
                                    Height="38"/>
                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="#4D5668"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Classes="section-title" Text="{Binding OrdersTitle}"/>
                        <ScrollViewer Grid.Row="2">
                            <ItemsControl ItemsSource="{Binding RecentOrders}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:Order">
                                        <Border BorderBrush="#E5EAF2"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,8">
                                            <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                                                <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding CustomerName}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                                               Classes="muted"/>
                                                    <TextBlock Text="{Binding StatusText}"
                                                               Foreground="#1F6FEB"
                                                               FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Total, StringFormat='{}{0:N0} ₸'}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#0B7A53"
                                                           VerticalAlignment="Center"/>
                                                </Grid>
                                                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                                                    <Button Classes="flat"
                                                            Content="{Binding #Root.DataContext.ApproveText}"
                                                            Command="{Binding #Root.DataContext.ApproveOrderCommand}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Classes="danger"
                                                            Content="{Binding #Root.DataContext.DeleteText}"
                                                            Command="{Binding #Root.DataContext.DeleteOrderCommand}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
                <Border Grid.Row="2" Classes="panel" IsVisible="{Binding IsCustomerPanelVisible}">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="section-title" Text="{Binding CustomerCabinetTitle}"/>
                        <TextBlock Text="{Binding CustomerCabinetHint}"
                                   Foreground="#4D5668"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding PhoneHint}"
                                   Classes="muted"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
        </Grid>
    </Grid>
</Window>
